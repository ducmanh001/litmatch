{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_PROJECT_DIR=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}\" node \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}/scripts/agent/session-start.mjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_PROJECT_DIR=\"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}\" node \"${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel)}/scripts/agent/pre-tool-guard.mjs\""
          }
        ]
      }
    ]
  }
}
