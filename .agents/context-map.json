{
  "default": {
    "description": "Định vị repo và chọn scope trước khi sửa",
    "read": [
      "AGENTS.md",
      "docs/00-overview-and-index.md",
      "docs/07-roadmap.md",
      "docs/11-engineering-principles.md"
    ],
    "checks": ["pnpm agent:check", "pnpm format:check", "pnpm lint"]
  },
  "core": {
    "description": "Modular monolith, module boundary và API backend",
    "read": [
      "AGENTS.md",
      "apps/core-api/AGENTS.md",
      "docs/03-architecture.md",
      "docs/05-coding-standards.md",
      "docs/10-code-review-checklist.md"
    ],
    "paths": ["apps/core-api/src", "libs"],
    "checks": [
      "pnpm agent:check",
      "pnpm nx run core-api:lint",
      "pnpm nx test core-api",
      "pnpm nx build core-api"
    ]
  },
  "economy": {
    "description": "Ledger, wallet, IAP, refund và mọi luồng chạm diamond",
    "read": [
      "AGENTS.md",
      "apps/core-api/AGENTS.md",
      "docs/02-domain-model.md",
      "docs/03-architecture.md",
      "docs/06-domain-rules.md",
      "docs/services/economy-service.md",
      "docs/10-code-review-checklist.md"
    ],
    "paths": [
      "apps/core-api/src/modules/economy",
      "apps/core-api/src/database/migrations"
    ],
    "invariants": [
      "LedgerEntry append-only là nguồn sự thật",
      "Idempotency unique ở Transaction",
      "Check và ghi tiền atomic trong DB transaction"
    ],
    "checks": [
      "pnpm agent:check",
      "INTEGRATION_DB_URL=postgresql://litmatch:litmatch_local@localhost:5432/litmatch_test pnpm nx test core-api --skip-nx-cache",
      "pnpm nx run core-api:lint",
      "pnpm nx build core-api"
    ]
  },
  "matching": {
    "description": "Ticket state machine, Redis shards, pairing, race conditions + Soul Match (chat ẩn danh, rating, Friendship) + Friend Chat 1-1",
    "read": [
      "AGENTS.md",
      "apps/core-api/AGENTS.md",
      "docs/03-architecture.md",
      "docs/06-domain-rules.md",
      "docs/services/matching-service.md",
      "docs/services/soul-match-service.md",
      "docs/services/friend-service.md",
      "docs/10-code-review-checklist.md"
    ],
    "paths": [
      "apps/core-api/src/modules/matching",
      "apps/core-api/src/modules/soul-match",
      "apps/core-api/src/modules/friend"
    ],
    "invariants": [
      "State transition hợp lệ và atomic",
      "Một user không được ghép vào hai session",
      "Redis là queue/index, Postgres giữ durable state",
      "Không leak danh tính/verdict đối phương trước khi match; phase phòng derive từ giờ server",
      "Friendship 1 dòng/cặp canonical, tạo trong cùng transaction với rating",
      "Conversation tạo atomically cùng Friendship — tồn tại Friendship ⟺ tồn tại Conversation"
    ],
    "checks": [
      "pnpm agent:check",
      "INTEGRATION_DB_URL=postgresql://litmatch:litmatch_local@localhost:5432/litmatch_test pnpm nx test core-api --skip-nx-cache",
      "pnpm nx run core-api:lint",
      "pnpm nx build core-api"
    ]
  },
  "calling": {
    "description": "Voice call 2 người trên LiveKit — CallSession lifecycle, token, free-call timer, billing theo phút",
    "read": [
      "AGENTS.md",
      "apps/core-api/AGENTS.md",
      "docs/03-architecture.md",
      "docs/06-domain-rules.md",
      "docs/services/calling-service.md",
      "docs/services/realtime-gateway.md",
      "docs/adr/0001-livekit-self-host-lam-media-server.md",
      "docs/10-code-review-checklist.md"
    ],
    "paths": [
      "apps/core-api/src/modules/calling",
      "apps/media-server",
      "apps/core-api/src/database/migrations"
    ],
    "invariants": [
      "Timer free-call + billing enforce ở server, không tin client",
      "ended là terminal; mọi transition idempotent (webhook retry an toàn)",
      "Billing tick idempotent theo (call, user, phút) — unique DB trên Transaction",
      "Mọi nhánh end đều deleteRoom LiveKit (không leak room)"
    ],
    "checks": [
      "pnpm agent:check",
      "INTEGRATION_DB_URL=postgresql://litmatch:litmatch_local@localhost:5432/litmatch_test pnpm nx test core-api --skip-nx-cache",
      "pnpm nx run core-api:lint",
      "pnpm nx build core-api"
    ]
  },
  "signaling": {
    "description": "WebSocket, room state và realtime signaling (fanout theo user — gateway không business logic)",
    "read": [
      "AGENTS.md",
      "apps/signaling-gateway/AGENTS.md",
      "docs/03-architecture.md",
      "docs/06-domain-rules.md",
      "docs/services/realtime-gateway.md",
      "docs/10-code-review-checklist.md"
    ],
    "paths": [
      "apps/signaling-gateway",
      "apps/signaling-gateway-e2e",
      "libs/common-dtos/src/lib/realtime-events.ts"
    ],
    "invariants": [
      "Gateway không business logic — authz/ẩn danh quyết ở core-api tại thời điểm publish",
      "Socket chỉ join room user của chính JWT đã verify, không nhận room từ client",
      "Publish best-effort SAU commit; REST polling là fallback"
    ],
    "checks": [
      "pnpm agent:check",
      "pnpm nx run signaling-gateway:lint",
      "pnpm nx test signaling-gateway",
      "pnpm nx build signaling-gateway",
      "pnpm nx e2e signaling-gateway-e2e"
    ]
  },
  "media": {
    "description": "LiveKit/SFU và media runtime",
    "read": [
      "AGENTS.md",
      "apps/media-server/AGENTS.md",
      "docs/03-architecture.md",
      "docs/04-tech-stack.md",
      "docs/10-code-review-checklist.md",
      "docs/adr/0001-livekit-self-host-lam-media-server.md"
    ],
    "paths": ["apps/media-server"],
    "checks": [
      "pnpm agent:check",
      "docker compose -f apps/media-server/docker-compose.yml config --quiet"
    ]
  },
  "infra": {
    "description": "CI, container, local tooling, security và agent infrastructure",
    "read": [
      "AGENTS.md",
      "docs/04-tech-stack.md",
      "docs/08-working-with-agents.md",
      "docs/11-engineering-principles.md"
    ],
    "paths": [
      ".github",
      ".agents",
      "scripts",
      "docker-compose.yml",
      "package.json"
    ],
    "checks": [
      "pnpm doctor",
      "pnpm agent:check",
      "pnpm agent:test",
      "pnpm format:check"
    ]
  }
}
