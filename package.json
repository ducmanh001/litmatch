    "wrangler": "^4.112.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
