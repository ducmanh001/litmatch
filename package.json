{
  "name": "litmatch",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22 <23"
  },
  "overrides": {
    "brace-expansion": "^2.0.1",
    "minimatch": "^9.0.5",
    "postcss": "^8.5.12"
  },
  "scripts": {
    "bootstrap": "pnpm install --frozen-lockfile && pnpm infra:up && pnpm db:migrate && pnpm doctor",
    "dev:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "dev:rebuild": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down --remove-orphans",
    "dev:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs --follow --tail=200",
    "dev:ps": "docker compose -f docker-compose.yml -f docker-compose.dev.yml ps",
    "dev:install": "docker compose -f docker-compose.yml -f docker-compose.dev.yml run --rm deps",
    "observability:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.observability.yml up -d alloy",
    "observability:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.observability.yml stop alloy",
    "observability:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.observability.yml logs --follow --tail=200 alloy",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "e2e": "nx run-many -t e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "agent:context": "node scripts/agent/context.mjs",
    "agent:verify": "node scripts/agent/verify.mjs",
    "agent:check": "node scripts/agent/repository-check.mjs",
    "agent:test": "node --test scripts/agent/*.test.mjs scripts/ci/*.test.mjs scripts/release/*.test.mjs",
    "ci:local:quick": "node scripts/ci/local.mjs quick",
    "ci:local:clean": "node scripts/ci/local.mjs clean",
    "ci:local": "node scripts/ci/local.mjs ci",
    "ci:local:docker": "node scripts/ci/local.mjs docker",
    "ci:local:security": "node scripts/ci/local.mjs security",
    "ci:local:all": "node scripts/ci/local.mjs all",
    "ci:local:plan": "node scripts/ci/local.mjs all --dry-run",
    "ci:local:test": "node --test scripts/ci/*.test.mjs",
    "ci:preflight": "node scripts/ci/local.mjs all",
    "openapi:emit": "nx run core-api:openapi-emit",
    "openapi:gen": "openapi-typescript openapi/core-api.json -o libs/api-client/src/generated/core-api.ts && prettier --write libs/api-client/src/generated/core-api.ts",
    "openapi:sync": "pnpm openapi:emit && pnpm openapi:gen",
    "openapi:check": "node scripts/agent/openapi-check.mjs",
    "doctor": "node scripts/doctor.mjs",
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down --remove-orphans",
    "infra:logs": "docker compose logs --follow --tail=200",
    "infra:reset": "docker compose down --volumes --remove-orphans",
    "db:migrate": "nx run core-api:migration-run",
    "db:status": "nx run core-api:migration-show",
    "db:revert": "nx run core-api:migration-revert",
    "verify": "pnpm format:check && pnpm lint && pnpm test && pnpm build",
    "release:preflight": "node scripts/release/release.mjs preflight",
    "release:deploy": "node scripts/release/release.mjs deploy",
    "release:backup": "node scripts/release/release.mjs backup",
    "release:smoke": "node scripts/release/release.mjs smoke",
    "release:rollback": "node scripts/release/release.mjs rollback",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/devkit": "23.0.1",
    "@nx/eslint": "^23.0.1",
    "@nx/eslint-plugin": "^23.0.1",
    "@nx/jest": "^23.0.1",
    "@nx/js": "^23.0.1",
    "@nx/nest": "^23.0.1",
    "@nx/next": "23.0.1",
