# Copy thành .env cho dev local. KHÔNG commit .env — file này chỉ chứa key + giá trị mẫu an toàn.

# --- chung ---
NODE_ENV=development
LOG_LEVEL=debug

# --- observability (Giai đoạn 6 — dùng chung core-api + signaling-gateway) ---
# Biến CHUẨN do chính OpenTelemetry spec định nghĩa (không đi qua Joi schema của app — xem
# libs/observability/src/lib/tracing.ts) — để trống thì KHÔNG khởi động tracing, tránh export
# lỗi âm thầm khi dev/test/CI chưa có collector (Jaeger/Tempo/OTel Collector) chạy sẵn.
# Ví dụ dev local với OTel Collector chạy ở :4318: OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- core-api ---
PORT=3000
# Origin các frontend browser (admin :4200, web :4300 — docs/12)
CORS_ORIGINS=http://localhost:4200,http://localhost:4300
SWAGGER_ENABLED=true

DATABASE_URL=postgresql://litmatch:litmatch_local@localhost:5432/litmatch
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092

# đổi 2 secret dưới đây ngay cả ở dev nếu máy dùng chung
JWT_SECRET=dev-only-secret-change-me-0123456789abcdef
JWT_ACCESS_TTL_SECONDS=900

AUTH_REFRESH_TTL_DAYS=30
AUTH_OTP_TTL_SECONDS=300
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_REQUESTS_PER_HOUR=5
AUTH_OTP_PEPPER=dev-only-pepper-change-me
AUTH_MIN_AGE=18
AUTH_GOOGLE_CLIENT_ID=
AUTH_APPLE_CLIENT_ID=

USER_DEFAULT_AVATAR_ID=default-01

# --- economy ---
# 'dev' = DevIapVerifier (receipt giả, chặn ở production); 'store' = Apple/Google thật (cần credential dưới)
ECONOMY_IAP_VERIFIER=dev
ECONOMY_APPLE_SHARED_SECRET=
ECONOMY_GOOGLE_PACKAGE_NAME=
ECONOMY_GOOGLE_SA_EMAIL=
ECONOMY_GOOGLE_SA_PRIVATE_KEY=
# Deadline cho mỗi request Apple/Google; timeout fail request/job thay vì treo worker vô hạn
ECONOMY_STORE_HTTP_TIMEOUT_MS=10000
ECONOMY_OUTBOX_RELAY_ENABLED=false
ECONOMY_OUTBOX_RELAY_INTERVAL_MS=2000
# Đối soát ledger 2 tier (docs/03 § 3.8.C): ENABLED=false tắt CẢ HAI tier.
# INTERVAL_MS = tier deep (sample ví, đắt); FAST_INTERVAL_MS = tier fast (bất biến Nợ=Có +
# orphan receipt, 1 câu aggregate) — chạy dày hơn để phát hiện lệch sớm, min 10000
ECONOMY_RECONCILIATION_ENABLED=true
ECONOMY_RECONCILIATION_INTERVAL_MS=300000
ECONOMY_RECONCILIATION_FAST_INTERVAL_MS=60000

# --- economy: refund/chargeback (docs/services/economy-service.md § 5) ---
# 'dev' = không verify chữ ký (local/test); 'store' = verify JWS chain / OIDC token thật
ECONOMY_APPLE_WEBHOOK_VERIFIER=dev
# PEM "Apple Root CA - G3" tải từ https://www.apple.com/certificateauthority/ — KHÔNG hardcode trong code
ECONOMY_APPLE_ROOT_CA_PEM=
ECONOMY_GOOGLE_RTDN_VERIFIER=dev
# URL endpoint webhook công khai đã khai khi tạo Pub/Sub push subscription (dùng làm audience OIDC)
ECONOMY_GOOGLE_RTDN_AUDIENCE=
ECONOMY_GOOGLE_RTDN_SERVICE_ACCOUNT_EMAIL=
# App Store Server API (job quét backstop "Get Refund History")
ECONOMY_APPLE_ISSUER_ID=
ECONOMY_APPLE_KEY_ID=
ECONOMY_APPLE_PRIVATE_KEY=
ECONOMY_APPLE_BUNDLE_ID=
ECONOMY_APPLE_SERVER_API_ENV=sandbox
ECONOMY_REFUND_POLL_ENABLED=false
ECONOMY_REFUND_POLL_INTERVAL_MS=3600000
ECONOMY_REFUND_POLL_WINDOW_DAYS=60

# --- matching (Giai đoạn 2 M1 — docs/03 § 3.8.B) ---
# Tuổi tối thiểu dùng lại AUTH_MIN_AGE, không tạo key trùng.
MATCHING_MATCHER_INTERVAL_MS=300
MATCHING_MATCHER_BATCH_SIZE=20
MATCHING_SWEEPER_INTERVAL_MS=5000
MATCHING_QUEUE_MAX_WAIT_SECONDS=120
MATCHING_CONFIRM_TIMEOUT_SECONDS=15
MATCHING_AGE_BAND_SIZE=5
MATCHING_SPEEDUP_PRICE_DIAMOND=50
MATCHING_SPEEDUP_MAX_PER_HOUR=3
# Điểm trừ khỏi score Redis (ms) khi speed-up — số càng lớn càng nổi lên đầu hàng đợi
MATCHING_PRIORITY_BOOST_MS=300000
# Trust score < 100 cộng thêm ms vào score (docs/services/safety-service.md § 3.2) — làm chậm
# priority, KHÔNG chặn hẳn matching; trần penalty tránh queue-starvation cho trust score rất thấp
MATCHING_TRUST_PENALTY_MS_PER_POINT=2000
MATCHING_TRUST_PENALTY_MAX_MS=120000

# --- soul match (Giai đoạn 2 — docs/services/soul-match-service.md § 6) ---
# Cửa sổ chat ẩn danh tính từ lúc cả 2 confirm (docs/06: 2-3 phút), enforce ở server
SOUL_CHAT_DURATION_SECONDS=150
# Cửa sổ đánh giá sau khi hết giờ chat; hết cửa sổ → phòng đóng hẳn
SOUL_RATING_WINDOW_SECONDS=120
SOUL_CHAT_MESSAGE_MAX_LENGTH=500

# --- friend chat 1-1 (Giai đoạn 2 — docs/services/friend-service.md § 7) ---
# Chat lâu dài giữa 2 bạn — không giới hạn ngắn như Soul Match
FRIEND_MESSAGE_MAX_LENGTH=2000

# --- livekit (dùng chung calling + party room — 1 cụm LiveKit, ADR 0001) ---
# URL ws LiveKit client nối; key/secret PHẢI khớp apps/media-server/livekit.yaml (dev = devkey)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_0123456789abcdef

# --- calling (Giai đoạn 2 — docs/services/calling-service.md § 6) ---
# Free window ~7 phút (docs/06) — hết giờ: price=0 thì server tự end, price>0 thì trừ diamond/phút CẢ 2 bên
CALLING_FREE_CALL_SECONDS=420
CALLING_PRICE_PER_MINUTE_DIAMOND=0
CALLING_PENDING_TIMEOUT_SECONDS=60
CALLING_TICKER_INTERVAL_MS=1000
CALLING_TOKEN_TTL_SECONDS=120

# --- party room (Giai đoạn 3 — docs/services/party-room-service.md § 7) ---
# Cap speaker là giới hạn CỨNG (docs/03 § 3.8.A: consumer tăng N×(N-1)) — chỉ nới khi có cascade SFU
PARTY_MAX_SPEAKERS=8
# LiveKit maxParticipants lúc tạo room — SFU chặn join vượt ngưỡng
PARTY_MAX_MEMBERS=100
PARTY_TOKEN_TTL_SECONDS=120
# LiveKit tự đóng room trống sau N giây — backstop cho phòng vô chủ
PARTY_EMPTY_ROOM_TIMEOUT_SECONDS=300
PARTY_SWEEPER_INTERVAL_MS=30000
# Phòng active không còn member active quá N giây → sweeper đóng (webhook có thể rớt)
PARTY_STALE_ROOM_SECONDS=120
PARTY_TITLE_MAX_LENGTH=100

# --- gift (Giai đoạn 3 — docs/services/gift-service.md) ---
# % giá quà (DIA) quy ra điểm PTS cho người nhận — PHẢI < 100 (docs/06 § Gift, chống rửa diamond)
GIFT_POINTS_RATE_PERCENT=40

# --- safety (Giai đoạn 4 — docs/services/safety-service.md) ---
# Không ghép lại nếu có report/block giữa 2 user trong X ngày gần nhất (docs/06)
SAFETY_REMATCH_COOLDOWN_DAYS=30
# 1 cặp (reporter, target) chỉ tính 1 report hiệu lực lên trust score mỗi X ngày — chống vote-kick
SAFETY_REPORT_COOLDOWN_DAYS=7
SAFETY_TRUST_PENALTY_PER_REPORT=5
# Trần tổng điểm trừ/ngày cho 1 target — chặn nhiều reporter khác nhau đánh sập trust score cùng lúc
SAFETY_TRUST_PENALTY_DAILY_CAP=20
SAFETY_TRUST_SCORE_FLOOR=0

# --- notification (Giai đoạn 4 — docs/services/notification-service.md) ---
# 'dev' = no-op (log), chặn cứng ở production — chưa có credential FCM/APNs thật
NOTIFICATION_PUSH_PROVIDER=dev

# --- movie match (Giai đoạn 5 — docs/services/movie-match-service.md § 8) ---
MOVIE_MATCH_URL_MAX_LENGTH=2048
# Danh sách domain video được phép, phân tách dấu phẩy (match hostname hoặc subdomain của host này)
MOVIE_MATCH_ALLOWED_VIDEO_HOSTS=youtube.com,youtu.be

# --- palm match (Giai đoạn 5 — docs/services/palm-match-service.md § 5) ---
PALM_MATCH_TARGET_NAME_MAX_LENGTH=50

THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# --- signaling-gateway ---
SIGNALING_PORT=3001
# Gateway VERIFY access token bằng CÙNG JWT_SECRET + subscribe CÙNG REDIS_URL với core-api
# (2 key đó khai ở phần core phía trên — không tạo key trùng tên riêng cho gateway)
