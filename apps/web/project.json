{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web",
  "projectType": "application",
  "tags": ["type:app", "scope:frontend"],
  "// targets": "to see all targets run: nx show project web --web",
  "targets": {
    "build": {
      "options": {
        "env": {
          "NODE_ENV": "production"
        }
      }
    },
    "dev": {
      "options": {
        "args": ["--port=4300"]
      }
    },
    "start": {
      "options": {
        "args": ["--port=4300"]
      }
    }
  }
}
