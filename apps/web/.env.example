NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
NEXT_PUBLIC_ENABLE_ERUDA=false
# Chỉ cần khi test dev server từ thiết bị khác (điện thoại) cùng mạng LAN — IP LAN của máy bạn,
# để trống thì Next chỉ chấp nhận origin localhost (next.config.js allowedDevOrigins).
DEV_LAN_IP=
# Host/origin dev bổ sung, phân tách dấu phẩy; ví dụ *.devtunnels.ms.
DEV_ALLOWED_ORIGINS=
NEXT_PUBLIC_AUTH_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_AUTH_APPLE_CLIENT_ID=
NEXT_PUBLIC_AUTH_FACEBOOK_APP_ID=
NEXT_PUBLIC_AUTH_FACEBOOK_API_VERSION=v24.0
NEXT_PUBLIC_PHONE_OTP_ENABLED=true
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=
# PostHog Cloud (optional): để trống cả hai thì analytics/session replay tắt hoàn toàn.
# Chọn host đúng region khi tạo project: https://eu.i.posthog.com hoặc https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=
