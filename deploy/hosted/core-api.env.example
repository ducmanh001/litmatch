NODE_ENV=production
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=https://litmatch-web.ACCOUNT.workers.dev,https://litmatch-admin.pages.dev
SWAGGER_ENABLED=false
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST:PORT
JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
AUTH_OTP_PEPPER=REPLACE_WITH_AT_LEAST_16_RANDOM_CHARACTERS
AUTH_PHONE_OTP_ENABLED=true
AUTH_COOKIE_SAME_SITE=none
ECONOMY_IAP_VERIFIER=disabled
ECONOMY_APPLE_WEBHOOK_VERIFIER=store
ECONOMY_GOOGLE_RTDN_VERIFIER=store
ECONOMY_OUTBOX_RELAY_ENABLED=false
ECONOMY_REFUND_POLL_ENABLED=false
NOTIFICATION_PUSH_PROVIDER=disabled
VIDEO_UPLOAD_ENABLED=false
LIVEKIT_URL=wss://PROJECT.livekit.cloud
LIVEKIT_API_URL=https://PROJECT.livekit.cloud
LIVEKIT_API_KEY=REPLACE_FROM_LIVEKIT_CLOUD
LIVEKIT_API_SECRET=REPLACE_FROM_LIVEKIT_CLOUD
