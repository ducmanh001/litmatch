# Public host. Tạo A record app/admin/api/realtime/media cùng trỏ về PUBLIC_IP.
DOMAIN=example.com
PUBLIC_IP=203.0.113.10
ACME_EMAIL=owner@example.com

# Google OAuth Web client dùng chung cho app + admin. Đây là client id công khai, không phải secret.
GOOGLE_OAUTH_CLIENT_ID=replace-me.apps.googleusercontent.com
# Facebook App ID is public; App Secret remains server-only in this protected host env.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Database password chỉ dùng A-Z/a-z/0-9/_/- để release script encode thống nhất vào DATABASE_URL.
POSTGRES_USER=litmatch
POSTGRES_PASSWORD=replace_with_random_url_safe_password
POSTGRES_DB=litmatch
POSTGRES_HOST_PORT=5432

# Tạo bằng: openssl rand -base64 48 (không commit file .env thật).
JWT_SECRET=replace_with_at_least_32_characters # gitleaks:allow
AUTH_OTP_PEPPER=replace_with_at_least_16_characters # gitleaks:allow
LIVEKIT_API_KEY=replace_with_random_key
LIVEKIT_API_SECRET=replace_with_at_least_32_characters # gitleaks:allow

# Optional PostHog Cloud Free; để trống cả hai thì analytics tắt.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=

# Optional Grafana Cloud Free; để trống toàn bộ thì Alloy không chạy.
GRAFANA_CLOUD_PROMETHEUS_URL=
GRAFANA_CLOUD_PROMETHEUS_USER=
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_API_TOKEN=

# Optional Sentry Cloud error monitoring. Leave all empty to disable; DSNs are public ingest IDs.
SENTRY_CORE_API_DSN=
SENTRY_SIGNALING_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_RELEASE=
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
SENTRY_RELEASE=
